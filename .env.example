# ╔══════════════════════════════════════════════════════════════════╗
# ║  Скопируй этот файл в .env и заполни значения.  cp .env.example .env ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Postgres (используется docker-compose для поднятия БД) ─────────────
POSTGRES_USER="terminal"
POSTGRES_PASSWORD="СГЕНЕРИРУЙ_СИЛЬНЫЙ_ПАРОЛЬ"
POSTGRES_DB="terminal_site"

# ── Строка подключения Prisma ─────────────────────────────────────────
# В DOCKER (compose): host = имя сервиса БД, т.е. "db".
DATABASE_URL="postgresql://terminal:ТОТ_ЖЕ_ПАРОЛЬ@db:5432/terminal_site?schema=public"
#
# ЛОКАЛЬНО без docker (npm run dev) — host обычно localhost:
# DATABASE_URL="postgresql://terminal:пароль@localhost:5432/terminal_site?schema=public"

# ── Auth.js (NextAuth v5) ─────────────────────────────────────────────
# Сгенерировать: openssl rand -hex 32
AUTH_SECRET=""
# Публичный URL. Локально — http://localhost:3000, в проде — https://твой-домен
AUTH_URL="http://localhost:3000"

# ── Почта (SMTP для писем верификации) ────────────────────────────────
# Пример для Resend (resend.com): верифицируй домен → возьми API-ключ.
#   SMTP_HOST="smtp.resend.com"
#   SMTP_PORT="465"
#   SMTP_USER="resend"
#   SMTP_PASS="re_xxxxxxxxxxxx"          # это API-ключ Resend
#   EMAIL_FROM="bash-app.com <noreply@send.bash-app.com>"   # адрес verified-домена
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
# От кого приходят письма. Домен ДОЛЖЕН быть верифицирован у провайдера.
EMAIL_FROM="bash-app.com <noreply@send.bash-app.com>"

# ── Шифрование токенов в БД (Spotify) ─────────────────────────────────
# Ключ AES-256 для шифрования сторонних токенов. openssl rand -hex 32
TOKEN_ENC_KEY=""

# ── Realtime-сервис чата (Socket.IO) ──────────────────────────────────
# Общий секрет: по нему app авторизует внутренний вызов рассылки к realtime.
# Генерация: openssl rand -hex 32. Наружу НЕ публикуется (только docker-сеть).
REALTIME_SECRET=""

# ── Супер-админы ──────────────────────────────────────────────────────
# Email'ы (через запятую) с доступом к /dashboard/admin (список юзеров,
# удаление учёток). Это обычные аккаунты — вход с паролем + 2FA, просто email
# совпадает со списком. Пример: SUPER_ADMIN_EMAILS="you@example.com"
SUPER_ADMIN_EMAILS=""

# ── Spotify (опционально — «now playing» в панели) ────────────────────
# developer.spotify.com/dashboard → Create app. Redirect URI ниже должен
# ТОЧНО совпадать с тем, что вписан в настройках приложения Spotify.
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="https://bash-app.com/api/spotify/callback"

# ── Прочее ────────────────────────────────────────────────────────────
# Имя сайта — в письмах и как issuer в приложении-аутентификаторе.
SITE_NAME="bash-app.com"
