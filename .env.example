# ╔══════════════════════════════════════════════════════════════════╗
# ║  Скопируй этот файл в .env и заполни значения.  cp .env.example .env ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Postgres (используется docker-compose для поднятия БД) ─────────────
POSTGRES_USER="terminal"
POSTGRES_PASSWORD="СГЕНЕРИРУЙ_СИЛЬНЫЙ_ПАРОЛЬ"
POSTGRES_DB="terminal_site"

# ── Строка подключения Prisma ─────────────────────────────────────────
# В DOCKER (compose): host = имя сервиса БД, т.е. "db".
DATABASE_URL="postgresql://terminal:ТОТ_ЖЕ_ПАРОЛЬ@db:5432/terminal_site?schema=public"
#
# ЛОКАЛЬНО без docker (npm run dev) — host обычно localhost:
# DATABASE_URL="postgresql://terminal:пароль@localhost:5432/terminal_site?schema=public"

# ── Auth.js (NextAuth v5) ─────────────────────────────────────────────
# Сгенерировать: openssl rand -hex 32
AUTH_SECRET=""
# Публичный URL. Локально — http://localhost:3000, в проде — https://твой-домен
AUTH_URL="http://localhost:3000"

# ── Почта (Gmail SMTP для писем верификации) ──────────────────────────
GMAIL_USER="you@gmail.com"
# App Password из Google (16 символов), НЕ обычный пароль:
# myaccount.google.com → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=""

# ── Прочее ────────────────────────────────────────────────────────────
# Имя сайта — в письмах и как issuer в приложении-аутентификаторе.
SITE_NAME="yourname.dev"
